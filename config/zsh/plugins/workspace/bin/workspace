#!/usr/bin/env zsh
# ghq → herdr workspace の薄いラッパ。
# workspace の一覧/切替/リネーム/削除は herdr native picker (prefix+w) に委譲する。

subcmd="${1:-new}"
shift 2>/dev/null

_resolve_repo_dir() {
  local repo="$1" dir match
  dir="$(ghq root)/$repo"
  if [[ ! -d "$dir" ]]; then
    match=$(ghq list | grep -E "/${repo}$" | head -1)
    [[ -z "$match" ]] && return 1
    dir="$(ghq root)/$match"
  fi
  [[ -d "$dir" ]] || return 1
  print -r -- "$dir"
}

# 同 label の workspace があれば focus、なければ create（label は repo 名に自動命名される）
_open_workspace() {
  local dir="$1" ws_id
  ws_id=$(herdr workspace list 2>/dev/null | jq -r --arg label "$(basename "$dir")" \
    '.result.workspaces[] | select(.label == $label) | .workspace_id' | head -1)
  if [[ -n "$ws_id" ]]; then
    herdr workspace focus "$ws_id" >/dev/null
  else
    herdr workspace create --cwd "$dir" >/dev/null
  fi
}

case "$subcmd" in
new)
  local dir
  if [[ -n "$1" ]]; then
    dir=$(_resolve_repo_dir "$1") || { echo "Repository not found: $1" >&2; exit 1; }
  else
    local repo
    repo=$(ghq list | fzf --reverse --header "Select repository")
    [[ -z "$repo" ]] && exit 0
    dir="$(ghq root)/$repo"
  fi
  _open_workspace "$dir"
  ;;

wt)
  local branch="$1"
  if [[ -z "$branch" ]]; then
    printf "Branch name: "
    read -r branch
  fi
  [[ -z "$branch" ]] && exit 0
  herdr worktree create --cwd "$PWD" --branch "$branch" >/dev/null
  ;;

wt-rm)
  local selected ws_id wt_path
  selected=$(herdr worktree list --cwd "$PWD" --json 2>/dev/null |
    jq -r '.result.worktrees[] | select(.is_linked_worktree) | "\(.open_workspace_id)\t\(.branch)\t\(.path)"' |
    fzf --reverse --delimiter '\t' --with-nth 2.. --header "Select worktree to remove")
  [[ -z "$selected" ]] && exit 0
  ws_id="${selected%%$'\t'*}"
  wt_path="${selected##*$'\t'}"
  # workspace が閉じている worktree は remove に --workspace が要るため開き直す
  if [[ -z "$ws_id" || "$ws_id" == "null" ]]; then
    ws_id=$(herdr worktree open --cwd "$PWD" --path "$wt_path" --no-focus --json |
      jq -r '.result.workspace.workspace_id')
  fi
  read -q "?Remove worktree '$wt_path'? [y/N] " || exit 0
  echo
  herdr worktree remove --workspace "$ws_id"
  ;;

*)
  exec "$0" new
  ;;
esac
