{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "cleanupPeriodDays": 30,
  "effortLevel": "xhigh",
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "bash-lsp@dotfiles-lsp": true,
    "example-skills@anthropic-agent-skills": true,
    "gopls-lsp@dotfiles-lsp": true,
    "lua-lsp@claude-plugins-official": false,
    "lua-lsp@dotfiles-lsp": true,
    "nixd-lsp@dotfiles-lsp": true,
    "rust-analyzer-lsp@dotfiles-lsp": true,
    "terraform-lsp@dotfiles-lsp": true,
    "vtsls-lsp@dotfiles-lsp": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "xhigh",
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "repo": "anthropics/skills",
        "source": "github"
      }
    },
    "dotfiles-lsp": {
      "source": {
        "path": ".",
        "source": "directory"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754030471611
  },
  "fileSuggestion": {
    "command": "~/.claude/file-suggestion.sh",
    "type": "command"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "~/.config/zsh/plugins/workspace/bin/workspace notify waiting",
            "type": "command"
          },
          {
            "command": "(~/.claude/hooks/notify.sh 'Awaiting Confirmation...' &)",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "mkdir -p ~/.claude/logs && echo \"[$(date '+%H:%M:%S')] $USER: $(jq -r '.tool_input.command')\" >> ~/.claude/logs/command_history_$(date '+%Y-%m-%d').log",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "~/.config/zsh/plugins/workspace/bin/workspace notify clear-state",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "jq -r 'if .tool_input.command | test(\"rm -rf|dd if=|:(){ :|:& };:\") then {\"decision\": \"block\", \"reason\": \"危険なコマンドは実行できません。別の方法を検討してください。\"} else empty end'",
            "type": "command"
          },
          {
            "command": "~/.claude/hooks/auto-approve-piped.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "~/.config/zsh/plugins/workspace/bin/workspace notify end",
            "type": "command"
          }
        ],
        "matcher": "prompt_input_exit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/yu-sz/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.config/zsh/plugins/workspace/bin/workspace notify idle",
            "type": "command"
          },
          {
            "command": "(~/.claude/hooks/notify.sh 'Task Completed!' &)",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "~/.config/zsh/plugins/workspace/bin/workspace notify clear-state",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(~/Projects/**/*)",
      "Read(~/.config/**/*)",
      "Read(~/.local/**/*)",
      "Read(~/.claude/**/*)",
      "Bash(eza:*)",
      "Bash(bat:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(gomi:*)",
      "Bash(jq:*)",
      "Bash(gh status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(echo:*)",
      "Bash(touch:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(man:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm test:*)",
      "Bash(yarn run:*)",
      "Bash(yarn test:*)",
      "Bash(bun run:*)",
      "Bash(bun test:*)",
      "Bash(curl:*)",
      "Bash(nix develop -c:*)",
      "WebSearch",
      "WebFetch"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git rebase:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh repo create:*)"
    ],
    "defaultMode": "plan",
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(git reset:*)",
      "Bash(gh repo delete:*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Read(**/.env.*)",
      "Write(**/.env*)",
      "Write(**/secrets/**)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(pnpm uninstall:*)",
      "Bash(pnpm remove:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)"
    ]
  },
  "showClearContextOnPlanAccept": true,
  "showThinkingSummaries": true,
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  }
}