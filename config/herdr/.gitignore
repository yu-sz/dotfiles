# ~/.config/herdr は本ディレクトリへの symlink。herdr が session.json / *.sock /
# *.log 等の runtime 状態をここへ書き込むため、宣言的 config 以外は追跡しない。
*
!.gitignore
!config.toml
!plugins/
!plugins/**
# plugins/config/<id>/ は herdr が plugin link 時に生成する per-plugin config dir
# (`herdr plugin config-dir` の出力先) のため runtime 状態として除外する。
plugins/config/
